# Environment Variables for Wikonomi
# Copy this file to .env and fill in your values

# Database Configuration (Production)
# Render provides DATABASE_URL automatically
DATABASE_URL=postgresql://username:password@host:port/database_name
DB_NAME=wikonomi_v2_db
DB_USER=wikonomi_v2_db_user
DB_PASSWORD=your_production_db_password
DB_HOST=dpg-d6hucudm5p6s73bqr7m0-a.singapore-postgres.render.com
DB_PORT=5432

# Email Configuration (Production)
EMAIL_HOST=mail.privateemail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@wikonomi.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=noreply@wikonomi.com

# OAuth Configuration (Production)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# Security (Production)
SECRET_KEY=your_production_secret_key

# Cloudflare R2 Storage (Production)
AWS_ACCESS_KEY_ID=your_r2_access_key
AWS_SECRET_ACCESS_KEY=your_r2_secret_key
AWS_STORAGE_BUCKET_NAME=wikonomi-media
AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_SIGNATURE_VERSION=s3v4

# Development Settings
DEBUG=True
DJANGO_SETTINGS_MODULE=wikonomi.local
